{
  "name": "teamhub",
  "version": "0.1.0",
  "private": true,
  "description": "TeamHub project management tool monorepo.",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently -n backend,frontend -c blue,green \"npm run dev --workspace @teamhub/backend\" \"npm run dev --workspace @teamhub/frontend\"",
    "build": "npm run build --workspaces",
    "lint": "npm run lint --workspaces",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md,yml,css,prisma}\"",
    "prisma:generate": "npm run prisma:generate --workspace @teamhub/backend",
    "prisma:migrate": "npm run prisma:migrate --workspace @teamhub/backend",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "prettier": "^3.3.3"
  },
  "engines": {
    "node": ">=20.11.0",
    "npm": ">=10.0.0"
  }
}
